# Admin login (panel protegido)
ADMIN_USER=admin
ADMIN_PASSWORD=admin

# Google Sheets API
# Opción A: Google Apps Script Web App URL (más simple, sin credenciales)
GOOGLE_APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbzXqSR9MdF7HeNzhxtAfRwwPuuqmOWLegmOWCAxynvpBUVgdYPVU3PoskLptdLcbldkoQ/exec

# Opción B: Google Sheets API con Service Account (más control)
# Descomenta si usas Service Account en lugar de Apps Script
# GOOGLE_SHEETS_API_KEY=
# GOOGLE_SHEET_ID=
# Ruta al JSON de la service account (contenido en base64 o path)
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Para desarrollo local con Apps Script solo necesitas:
# ADMIN_USER, ADMIN_PASSWORD, GOOGLE_APPS_SCRIPT_URL
